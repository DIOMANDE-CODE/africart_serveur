# --- DJANGO CORE SETTINGS ---
DEBUG=True
# Générez une clé secrète pour la production
SECRET_KEY=django-insecure-votre-cle-ici

# --- SÉCURITÉ & RÉSEAU (CORS / CSRF / HOSTS) ---
# Liste des hôtes autorisés séparés par des virgules
ALLOWED_HOSTS=liste_des_hotes_autorises

# Origines autorisées pour les requêtes Cross-Origin (Frontend)
CORS_ALLOWED_ORIGINS=origine1,origine2,origine3

# Origines de confiance pour les formulaires et l'admin
CSRF_TRUSTED_ORIGINS=origine1,origine2,origine3

# --- CONFIGURATION CLOUDINARY (STOCKAGE IMAGES) ---
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# GEMINI API KEY
GEMINI_API_KEY=votre_gemini_api_key

